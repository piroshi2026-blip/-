# PDCA 自動化（.env.local / Vercel に追記）
#
# 毎日の流れ（vercel.json の UTC → JST）
# ・pdca-plan … JST 8:00 相当（前日 23:00 UTC）に①調査で5枠の種を保存
# ・pdca-slot/0〜4 … JST 9,11,13,15,17（各2時間おき）に②問い作成→③公開→④X告知
# ・pdca-analyze … JST 23:00 相当（14:00 UTC）に⑤前日の集計ログ
#
# 必須
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# SUPABASE_SERVICE_ROLE_KEY
#   Supabase ダッシュボード → 左「Project Settings」→「API」
#   → Project API keys の「service_role」（secret）を表示してコピー。
#   絶対に Git やフロントに埋め込まない。サーバー／Vercel のみ。
#
# CRON_SECRET
#   端末で「npm run generate:cron-secret」を実行し、出た64文字をコピーして
#   .env.local と Vercel の両方に同じ値を入れる（Cron 用の共有パスワード）。
#
# SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET=
#
# X 自動投稿（④）
# TWITTER_API_KEY= TWITTER_API_SECRET= TWITTER_ACCESS_TOKEN= TWITTER_ACCESS_SECRET=
#
# 推奨
# PDCA_PUBLIC_SITE_URL= または NEXT_PUBLIC_SITE_URL=
#
# X 投稿（Developer Portal で Read and Write。OAuth 1.0a ユーザーコンテキスト）
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
#
# 任意（話題のブラッシュアップ。未設定ならテンプレ草案のみ）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# 任意（RSS を追加。カンマ区切り）
# RSS_FEED_URLS=https://example.com/feed.xml
# 大谷・ドジャース用にスポーツ専門RSSを追加する場合（未設定時はヤフースポーツ等から自動抽出）
# OHTANI_RSS_FEEDS=https://example.com/mlb.xml
#
# 任意（締め切りまでの日数の既定）
# PDCA_DEFAULT_END_DAYS=7
